---
interface Certificate {
	name: string;
	date?: string;
	issuer?: string;
	url?: string;
	highlights?: string[];
}

interface Props {
	certificates: Certificate[];
}

const { certificates } = Astro.props;

const formatDate = (dateStr?: string) => {
	if (!dateStr) return "";
	if (dateStr.length === 4) return dateStr;
	const date = new Date(dateStr);
	return date.toLocaleDateString("en-US", { month: "short", year: "numeric" });
};
---

<section class="relative py-24 px-6 section-reveal" id="certifications">
	<div class="max-w-4xl mx-auto">
		<!-- Section header -->
		<div class="flex items-center gap-4 mb-16">
			<div class="flex items-center gap-3">
				<div class="w-2 h-2 rounded-full bg-[#f472b6] shadow-[0_0_10px_rgba(244,114,182,0.5)]"></div>
				<h2 class="text-3xl font-bold tracking-tight" style="font-family: var(--font-display);">
					<span style="font-family: var(--font-organic); font-style: italic; color: #f472b6;">Certifications</span>
				</h2>
			</div>
			<div class="flex-1 organic-divider"></div>
		</div>

		<div class="grid gap-4 md:grid-cols-2">
			{certificates.map((cert) => (
				<div class="glass-card glass-card-hover rounded-xl p-5 cert-card flex items-start gap-4">
					<div class="shrink-0 w-10 h-10 rounded-lg flex items-center justify-center" style="background: rgba(74,222,128,0.08); border: 1px solid rgba(74,222,128,0.15);">
						<svg class="w-5 h-5 text-[#4ade80]" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
							<path d="M3.85 8.62a4 4 0 0 1 4.78-4.77a4 4 0 0 1 6.74 0a4 4 0 0 1 4.78 4.78a4 4 0 0 1 0 6.74a4 4 0 0 1-4.77 4.78a4 4 0 0 1-6.75 0a4 4 0 0 1-4.78-4.77a4 4 0 0 1 0-6.76" />
							<path d="m9 12l2 2l4-4" />
						</svg>
					</div>
					<div class="flex-1 min-w-0">
						<h3 class="font-bold text-white text-sm" style="font-family: var(--font-display);">
							{cert.url ? (
								<a href={cert.url} target="_blank" rel="noopener noreferrer" class="hover:text-[#4ade80] transition-colors">
									{cert.name}
								</a>
							) : (
								cert.name
							)}
						</h3>
						<div class="flex flex-wrap items-center gap-2 text-xs text-white/70 mt-1" style="font-family: var(--font-mono);">
							{cert.issuer && <span>{cert.issuer}</span>}
							{cert.issuer && cert.date && <span class="text-white/10">|</span>}
							{cert.date && <span>{formatDate(cert.date)}</span>}
						</div>
						{cert.highlights && cert.highlights.length > 0 && (
							<ul class="mt-2">
								{cert.highlights.map((highlight) => (
									<li class="text-xs text-white/90 flex items-start gap-2">
										<span class="text-[#4ade80] opacity-50">›</span>
										<span>{highlight}</span>
									</li>
								))}
							</ul>
						)}
					</div>
				</div>
			))}
		</div>
	</div>
</section>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	gsap.registerPlugin(ScrollTrigger);

	gsap.set('.cert-card', { opacity: 0, y: 30 });
	ScrollTrigger.batch('.cert-card', {
		start: 'top 88%',
		onEnter: (batch) => gsap.to(batch, { opacity: 1, y: 0, duration: 0.6, stagger: 0.08, ease: 'power3.out' }),
		once: true,
	});
</script>
