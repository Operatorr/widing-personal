---
interface Project {
  name: string;
  description?: string;
  highlights?: string[];
  keywords?: string[];
  startDate?: string;
  endDate?: string;
  url?: string;
  roles?: string[];
  entity?: string;
  type?: string;
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

const formatDate = (dateStr?: string) => {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
};

const projectColors = [
  '#2dd4bf',
  '#4ade80',
  '#c084fc',
  '#22d3ee',
  '#f472b6',
  '#60a5fa',
];
---

<section class="relative py-24 px-6 overflow-hidden section-reveal" id="projects">
  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1561340903-ff1ac8a3a162?w=1920&q=80"
      alt=""
      class="w-full h-full object-cover opacity-25"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-b from-[#0a0f0a] via-[#0a0f0a]/50 to-[#0a0f0a]"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-[#0a0f0a] via-transparent to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto">
    <!-- Section header -->
    <div class="flex items-center gap-4 mb-16">
      <div class="flex items-center gap-3">
        <div class="w-2 h-2 rounded-full bg-[#2dd4bf] shadow-[0_0_10px_rgba(45,212,191,0.5)]"></div>
        <h2 class="text-3xl font-bold tracking-tight" style="font-family: var(--font-display);">
          Selected <span style="font-family: var(--font-organic); font-style: italic; color: #2dd4bf;">Projects</span>
        </h2>
      </div>
      <div class="flex-1 organic-divider"></div>
    </div>

    <div class="grid gap-5 md:grid-cols-2">
      {projects.map((project, i) => {
        const color = projectColors[i % projectColors.length];
        return (
          <div class="glass-card glass-card-hover rounded-xl p-6 project-card" style={`border-color: ${color}20;`}>
            <!-- Header -->
            <div class="flex items-start justify-between gap-2 mb-3">
              <div>
                <h3 class="font-bold text-white tracking-tight" style="font-family: var(--font-display);">
                  {project.url ? (
                    <a href={project.url} target="_blank" rel="noopener noreferrer" class="hover:underline transition-colors inline-flex items-center gap-1.5" style={`color: ${color};`}>
                      {project.name}
                      <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/>
                        <polyline points="15 3 21 3 21 9"/>
                        <line x1="10" x2="21" y1="14" y2="3"/>
                      </svg>
                    </a>
                  ) : (
                    <span style={`color: ${color};`}>{project.name}</span>
                  )}
                </h3>
                {project.entity && (
                  <p class="text-xs text-white/40 mt-0.5" style="font-family: var(--font-mono);">{project.entity}</p>
                )}
              </div>
              {project.startDate && (
                <span class="text-[10px] tracking-wider text-white/30 whitespace-nowrap" style="font-family: var(--font-mono);">
                  {formatDate(project.startDate)} — {project.endDate ? formatDate(project.endDate) : 'Now'}
                </span>
              )}
            </div>

            {project.description && (
              <p class="text-sm text-white/90 leading-relaxed" style="font-weight: 300;">{project.description}</p>
            )}

            {project.roles && project.roles.length > 0 && (
              <div class="flex flex-wrap gap-1.5 mt-3">
                {project.roles.map((role) => (
                  <span class="text-[10px] tracking-wider uppercase px-2 py-0.5 rounded-full" style={`font-family: var(--font-mono); color: ${color}; background: ${color}15; border: 1px solid ${color}25;`}>
                    {role}
                  </span>
                ))}
              </div>
            )}

            {project.highlights && project.highlights.length > 0 && (
              <ul class="mt-4 space-y-1.5">
                {project.highlights.map((highlight) => (
                  <li class="text-xs text-white/90 flex items-start gap-2">
                    <svg class="w-3 h-3 mt-0.5 shrink-0 opacity-40" style={`color: ${color};`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                      <path d="M20 6 9 17l-5-5"/>
                    </svg>
                    <span>{highlight}</span>
                  </li>
                ))}
              </ul>
            )}

            {project.keywords && project.keywords.length > 0 && (
              <div class="flex flex-wrap gap-1 mt-4 pt-3" style={`border-top: 1px solid ${color}10;`}>
                {project.keywords.map((keyword) => (
                  <span class="skill-tag text-[10px] px-1.5 py-0.5 rounded" style={`font-family: var(--font-mono); color: ${color}; opacity: 0.5; background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.04);`}>
                    {keyword}
                  </span>
                ))}
              </div>
            )}
          </div>
        );
      })}
    </div>
  </div>
</div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const projectCards = document.querySelectorAll('.project-card');
  projectCards.forEach((card, i) => {
    gsap.fromTo(card,
      { opacity: 0, y: 40 },
      {
        opacity: 1,
        y: 0,
        duration: 0.7,
        delay: (i % 2) * 0.15,
        ease: 'power3.out',
        scrollTrigger: {
          trigger: card,
          start: 'top 88%',
          toggleActions: 'play none none none',
        }
      }
    );
  });
</script>
