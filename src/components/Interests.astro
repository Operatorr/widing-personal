---
interface Interest {
	name: string;
	keywords?: string[];
}

interface Props {
	interests: Interest[];
}

const { interests } = Astro.props;

const getInterestIcon = (name: string) => {
	const lower = name.toLowerCase();
	if (lower.includes("climbing")) return "climbing";
	if (lower.includes("fitness") || lower.includes("nutrition")) return "fitness";
	if (lower.includes("photo")) return "camera";
	if (lower.includes("car")) return "car";
	if (lower.includes("warcraft") || lower.includes("gaming") || lower.includes("game")) return "gamepad";
	return "star";
};

const interestColors = ['#4ade80', '#c084fc', '#f472b6', '#22d3ee', '#60a5fa'];
---

<section class="relative py-24 px-6 overflow-hidden section-reveal" id="interests">
	<!-- Background image with dark fade -->
	<div class="absolute inset-0 z-0">
		<img
			src="https://images.unsplash.com/photo-1508080616348-b9b19ce377b9?w=1920&q=80"
			alt=""
			class="w-full h-full object-cover opacity-30"
			loading="lazy"
		/>
		<div class="absolute inset-0 bg-gradient-to-b from-[#0a0f0a] via-[#0a0f0a]/50 to-[#0a0f0a]"></div>
		<div class="absolute inset-0 bg-gradient-to-t from-[#0a0f0a] via-transparent to-transparent opacity-80"></div>
	</div>

	<div class="relative z-10 max-w-4xl mx-auto">
		<!-- Section header -->
		<div class="flex items-center gap-4 mb-16">
			<div class="flex items-center gap-3">
				<div class="w-2 h-2 rounded-full bg-[#f472b6] shadow-[0_0_10px_rgba(244,114,182,0.5)]"></div>
				<h2 class="text-3xl font-bold tracking-tight" style="font-family: var(--font-display);">
					Interests & <span style="font-family: var(--font-organic); font-style: italic; color: #f472b6;">Activities</span>
				</h2>
			</div>
			<div class="flex-1 organic-divider"></div>
		</div>

		<div class="grid gap-4 md:grid-cols-2">
			{interests.map((interest, i) => {
				const color = interestColors[i % interestColors.length];
				const iconType = getInterestIcon(interest.name);
				return (
					<div class="glass-card glass-card-hover rounded-xl p-5 interest-card" style={`border-color: ${color}15;`}>
						<h3 class="font-bold text-white text-sm flex items-center gap-2.5" style="font-family: var(--font-display);">
							<span class="w-6 h-6 rounded-lg flex items-center justify-center" style={`background: ${color}12; border: 1px solid ${color}20;`}>
								{iconType === "climbing" && (
									<svg class="w-3.5 h-3.5" style={`color: ${color};`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path>
										<circle cx="9" cy="7" r="4"></circle>
										<path d="m16 11 2 2 4-4"></path>
									</svg>
								)}
								{iconType === "fitness" && (
									<svg class="w-3.5 h-3.5" style={`color: ${color};`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M18 8h1a4 4 0 0 1 0 8h-1"></path>
										<path d="M2 8h16v9a4 4 0 0 1-4 4H6a4 4 0 0 1-4-4V8z"></path>
									</svg>
								)}
								{iconType === "camera" && (
									<svg class="w-3.5 h-3.5" style={`color: ${color};`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M14.5 4h-5L7 7H4a2 2 0 0 0-2 2v9a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2h-3l-2.5-3z"></path>
										<circle cx="12" cy="13" r="3"></circle>
									</svg>
								)}
								{iconType === "car" && (
									<svg class="w-3.5 h-3.5" style={`color: ${color};`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<path d="M19 17h2c.6 0 1-.4 1-1v-3c0-.9-.7-1.7-1.5-1.9C18.7 10.6 16 10 16 10s-1.3-1.4-2.2-2.3c-.5-.4-1.1-.7-1.8-.7H5c-.6 0-1.1.4-1.4.9l-1.4 2.9A3.7 3.7 0 0 0 2 12v4c0 .6.4 1 1 1h2"></path>
										<circle cx="7" cy="17" r="2"></circle>
										<circle cx="17" cy="17" r="2"></circle>
									</svg>
								)}
								{iconType === "gamepad" && (
									<svg class="w-3.5 h-3.5" style={`color: ${color};`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<line x1="6" x2="10" y1="12" y2="12"></line>
										<line x1="8" x2="8" y1="10" y2="14"></line>
										<line x1="15" x2="15.01" y1="13" y2="13"></line>
										<line x1="18" x2="18.01" y1="11" y2="11"></line>
										<rect width="20" height="12" x="2" y="6" rx="2"></rect>
									</svg>
								)}
								{iconType === "star" && (
									<svg class="w-3.5 h-3.5" style={`color: ${color};`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
										<polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
									</svg>
								)}
							</span>
							{interest.name}
						</h3>
						{interest.keywords && interest.keywords.length > 0 && (
							<div class="mt-3 flex flex-wrap gap-1.5">
								{interest.keywords.map((keyword) => (
									<span class="skill-tag text-[11px] px-2 py-1 rounded-md text-white/90" style={`font-family: var(--font-mono); background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.06);`}>
										{keyword}
									</span>
								))}
							</div>
						)}
					</div>
				);
			})}
		</div>
	</div>
</section>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';
	gsap.registerPlugin(ScrollTrigger);

	// Parallax on the background image
	const bgImg = document.querySelector('#interests img');
	if (bgImg) {
		gsap.to(bgImg, {
			yPercent: 20,
			ease: 'none',
			scrollTrigger: {
				trigger: '#interests',
				start: 'top bottom',
				end: 'bottom top',
				scrub: 1,
			}
		});
	}

	document.querySelectorAll('.interest-card').forEach((card, i) => {
		gsap.fromTo(card,
			{ opacity: 0, y: 30 },
			{
				opacity: 1, y: 0, duration: 0.6,
				delay: (i % 2) * 0.1,
				ease: 'power3.out',
				scrollTrigger: { trigger: card, start: 'top 88%', toggleActions: 'play none none none' }
			}
		);
	});
</script>
