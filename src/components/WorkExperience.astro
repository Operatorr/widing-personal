---
interface WorkItem {
  name: string;
  location?: string;
  description?: string;
  position: string;
  url?: string;
  startDate: string;
  endDate?: string;
  summary?: string;
  highlights?: string[];
}

interface Props {
  work: WorkItem[];
}

const { work } = Astro.props;

const formatDate = (dateStr: string) => {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
};

const accentColors = [
  { border: 'rgba(74,222,128,0.2)', glow: 'rgba(74,222,128,0.05)', text: '#4ade80' },
  { border: 'rgba(192,132,252,0.2)', glow: 'rgba(192,132,252,0.05)', text: '#c084fc' },
  { border: 'rgba(45,212,191,0.2)', glow: 'rgba(45,212,191,0.05)', text: '#2dd4bf' },
  { border: 'rgba(34,211,238,0.2)', glow: 'rgba(34,211,238,0.05)', text: '#22d3ee' },
  { border: 'rgba(96,165,250,0.2)', glow: 'rgba(96,165,250,0.05)', text: '#60a5fa' },
  { border: 'rgba(244,114,182,0.2)', glow: 'rgba(244,114,182,0.05)', text: '#f472b6' },
];
---

<section class="relative py-24 px-6 overflow-hidden" id="experience">
  <!-- Background image -->
  <div class="absolute inset-0 z-0">
    <img
      src="https://images.unsplash.com/photo-1660238271280-2b390999ace4?w=1920&q=80"
      alt=""
      class="w-full h-full object-cover opacity-25"
      loading="lazy"
    />
    <div class="absolute inset-0 bg-linear-to-b from-[#0a0f0a] via-[#0a0f0a]/50 to-[#0a0f0a]"></div>
    <div class="absolute inset-0 bg-linear-to-t from-[#0a0f0a] via-transparent to-transparent"></div>
  </div>

  <div class="relative z-10 max-w-4xl mx-auto">
    <!-- Section header -->
    <div class="flex items-center gap-4 mb-16">
      <div class="flex items-center gap-3">
        <div class="w-2 h-2 rounded-full bg-[#4ade80] shadow-[0_0_10px_rgba(74,222,128,0.5)]"></div>
        <h2 class="text-3xl font-bold tracking-tight" style="font-family: var(--font-display);">
          Work <span style="font-family: var(--font-organic); font-style: italic; color: #c084fc;">Experience</span>
        </h2>
      </div>
      <div class="flex-1 organic-divider"></div>
    </div>

    <!-- Stacking cards -->
    <div class="space-y-6" id="work-cards">
      {work.map((job, i) => {
        const accent = accentColors[i % accentColors.length];
        return (
          <div
            class="work-card glass-card glass-card-hover rounded-xl p-6 md:p-8"
            style={`border-color: ${accent.border}; --accent: ${accent.text};`}
            data-index={i}
          >
            <!-- Header row -->
            <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-3">
              <div>
                <div class="flex items-center gap-2 mb-1">
                  <div class="w-1.5 h-1.5 rounded-full" style={`background: ${accent.text}; box-shadow: 0 0 8px ${accent.glow};`}></div>
                  <span class="text-[10px] tracking-[0.25em] uppercase" style={`font-family: var(--font-mono); color: ${accent.text}; opacity: 0.7;`}>
                    {formatDate(job.startDate)} — {job.endDate ? formatDate(job.endDate) : 'Present'}
                  </span>
                </div>
                <h3 class="text-xl font-bold text-white tracking-tight" style="font-family: var(--font-display);">
                  {job.position}
                </h3>
                <div class="flex flex-wrap items-center gap-2 mt-1">
                  {job.url ? (
                    <a href={job.url} target="_blank" rel="noopener noreferrer" class="text-sm hover:underline transition-colors" style={`color: ${accent.text};`}>
                      {job.name}
                    </a>
                  ) : (
                    <span class="text-sm" style={`color: ${accent.text}; opacity: 0.8;`}>{job.name}</span>
                  )}
                  {job.location && (
                    <>
                      <span class="text-white/10">|</span>
                      <span class="text-xs text-white/40" style="font-family: var(--font-mono);">{job.location}</span>
                    </>
                  )}
                </div>
              </div>
            </div>

            {job.summary && (
              <p class="text-white/90 mt-4 text-sm leading-relaxed" style="font-family: var(--font-sans); font-weight: 300;">
                {job.summary}
              </p>
            )}

            {job.highlights && job.highlights.length > 0 && (
              <ul class="mt-5 space-y-2.5">
                {job.highlights.map((highlight) => (
                  <li class="text-sm text-white/90 flex items-start gap-3">
                    <svg class="w-3 h-3 mt-1.5 shrink-0" style={`color: ${accent.text}; opacity: 0.5;`} fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="m9 18 6-6-6-6"/>
                    </svg>
                    <span>{highlight}</span>
                  </li>
                ))}
              </ul>
            )}
          </div>
        );
      })}
    </div>
  </div>
</div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  // Work card entrance animations — batched
  gsap.set('.work-card', { opacity: 0, y: 40 });
  ScrollTrigger.batch('.work-card', {
    start: 'top 88%',
    onEnter: (batch) => gsap.to(batch, { opacity: 1, y: 0, duration: 0.7, stagger: 0.08, ease: 'power3.out' }),
    once: true,
  });
</script>
