---
interface Props {
  name: string;
}
const { name } = Astro.props;
const initials = name.split(' ').map(n => n[0]).join('');
---

<nav id="navbar" class="fixed top-4 left-1/2 -translate-x-1/2 z-50 transition-[background-color,border-color,box-shadow] duration-500 px-6 py-3 rounded-full" style="background: transparent;">
  <div class="flex items-center gap-6">
    <span id="nav-logo" class="font-bold text-sm tracking-widest text-white/90 transition-colors duration-500" style="font-family: var(--font-display);">
      {initials}
    </span>
    <div class="flex items-center gap-4">
      <a href="#experience" class="nav-link text-xs tracking-wider uppercase text-white/60 hover:text-white focus-visible:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#4ade80]/50 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a0f0a] rounded-sm transition-colors duration-300" style="font-family: var(--font-mono);">Experience</a>
      <a href="#skills" class="nav-link text-xs tracking-wider uppercase text-white/60 hover:text-white focus-visible:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#4ade80]/50 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a0f0a] rounded-sm transition-colors duration-300" style="font-family: var(--font-mono);">Skills</a>
      <a href="#projects" class="nav-link text-xs tracking-wider uppercase text-white/60 hover:text-white focus-visible:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#4ade80]/50 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a0f0a] rounded-sm transition-colors duration-300" style="font-family: var(--font-mono);">Projects</a>
      <a href="/cv" class="magnetic-btn text-xs tracking-wider uppercase px-4 py-1.5 border border-white/20 rounded-full text-white/70 hover:text-white hover:border-[#4ade80]/40 focus-visible:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[#4ade80]/50 focus-visible:ring-offset-2 focus-visible:ring-offset-[#0a0f0a] transition-all duration-300" style="font-family: var(--font-mono);">PDF</a>
    </div>
  </div>
</nav>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  const navbar = document.getElementById('navbar');
  const navLogo = document.getElementById('nav-logo');
  const navLinks = document.querySelectorAll('.nav-link');

  let isScrolled = false;

  if (navbar) {
    ScrollTrigger.create({
      start: 'top -100',
      onUpdate: (self) => {
        if (self.direction === 1 && self.progress > 0.01) {
          isScrolled = true;
          // Scrolling down — solid bg (no backdrop-filter)
          navbar.style.background = 'rgba(10, 15, 10, 0.92)';
          navbar.style.border = '1px solid rgba(74, 222, 128, 0.1)';
          navbar.style.boxShadow = '0 4px 30px rgba(0,0,0,0.3)';
          if (navLogo) navLogo.style.color = '#4ade80';
          updateNavLinkColors();
        }
        if (self.progress < 0.01) {
          isScrolled = false;
          // At the top — transparent
          navbar.style.background = 'transparent';
          navbar.style.border = 'none';
          navbar.style.boxShadow = 'none';
          if (navLogo) navLogo.style.color = 'rgba(255,255,255,0.9)';
          updateNavLinkColors();
        }
      }
    });
  }

  // Active section tracking
  let activeSection = '';

  function updateNavLinkColors() {
    navLinks.forEach(l => {
      const link = l as HTMLElement;
      const href = link.getAttribute('href') || '';
      const isActive = href === `#${activeSection}`;

      if (isScrolled) {
        link.style.color = isActive ? '#4ade80' : 'rgba(74,222,128,0.5)';
      } else {
        link.style.color = isActive ? 'rgba(255,255,255,1)' : 'rgba(255,255,255,0.6)';
      }
    });
  }

  const sectionIds = ['experience', 'skills', 'projects'];
  const sectionEls = sectionIds.map(id => document.getElementById(id)).filter(Boolean) as HTMLElement[];

  if (sectionEls.length > 0) {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          activeSection = entry.target.id;
          updateNavLinkColors();
        }
      });
    }, { rootMargin: '-20% 0px -60% 0px' });

    sectionEls.forEach(el => observer.observe(el));
  }
</script>
