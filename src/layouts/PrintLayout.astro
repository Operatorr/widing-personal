---
import '../styles/global.css';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="bg-white text-zinc-900 font-sans antialiased print-layout">
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --font-sans: 'Noto Sans', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  body {
    font-family: var(--font-sans);
  }

  .print-layout {
    max-width: 210mm;
    margin: 0 auto;
    padding: 0;
  }

  /* Print styles */
  @media print {
    @page {
      size: A4;
      margin: 10mm 12mm;
    }

    html, body {
      width: 210mm;
      font-size: 10pt;
      background: white !important;
      -webkit-print-color-adjust: exact !important;
      print-color-adjust: exact !important;
    }

    .print-layout {
      max-width: none;
      padding: 0;
      font-size: 10pt;
      line-height: 1.4;
    }

    .no-print {
      display: none !important;
    }

    .avoid-break {
      break-inside: avoid;
    }

    .break-before {
      break-before: page;
    }
  }

  /* Screen preview styles */
  @media screen {
    body {
      background: #f5f5f5;
      padding: 20px;
    }

    .print-layout {
      background: white;
      box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
      padding: 15mm;
    }
  }
</style>
