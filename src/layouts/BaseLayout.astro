  // Python syntax highlighter
  function highlightPython(code: string): string {
    // HTML-escape
    let html = code.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');

    // Tokenize with ordered replacements (use placeholder system to avoid double-matching)
    const tokens: { placeholder: string; replacement: string }[] = [];
    let tokenId = 0;
    function stash(match: string, cls: string): string {
      const ph = `\x00T${tokenId++}\x00`;
      tokens.push({ placeholder: ph, replacement: `<span class="${cls}">${match}</span>` });
      return ph;
    }

    // Comments
    html = html.replace(/#[^\n]*/g, m => stash(m, 'py-comment'));
    // Strings (triple-quoted and single/double)
    html = html.replace(/(&quot;{3}[\s\S]*?&quot;{3}|'{3}[\s\S]*?'{3}|&quot;(?:[^\\&]|\\.)*?&quot;|'(?:[^\\']|\\.)*?')/g, m => stash(m, 'py-str'));
    // Also match regular double-quoted strings
    html = html.replace(/"(?:[^\\"]|\\.)*?"/g, m => stash(m, 'py-str'));
    // Keywords
    const kws = 'def|class|return|if|elif|else|for|while|in|not|and|or|is|import|from|as|with|try|except|finally|raise|pass|break|continue|lambda|yield|True|False|None';
    html = html.replace(new RegExp(`\\b(${kws})\\b`, 'g'), m => stash(m, 'py-kw'));
    // Builtins
    const builtins = 'print|len|range|enumerate|min|max|abs|sum|sorted|list|dict|set|tuple|int|float|str|bool|zip|map|filter|type|isinstance|hasattr|getattr|setattr|super|all|any|deque|defaultdict|OrderedDict|inf';
    html = html.replace(new RegExp(`\\b(${builtins})\\b`, 'g'), m => stash(m, 'py-builtin'));
    // Numbers
    html = html.replace(/\b\d+(\.\d+)?\b/g, m => stash(m, 'py-num'));
    // Function/class names after def/class keywords
    html = html.replace(/(?<=\x00T\d+\x00\s)\w+/g, m => stash(m, 'py-def'));

    // Restore tokens
    tokens.forEach(t => {
      html = html.replace(t.placeholder, t.replacement);
    });

    return html;
  }

