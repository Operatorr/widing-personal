      for (let i = 0; i < 5; i++)
        setTimeout(() => spawnSmoke(2 + Math.random() * 4, 37 + Math.random() * 3, 'rgba(34,211,238,0.14)'), i * 120);
    }, [], 1.05);

    // ── 1.1s: Biplane zooms right-to-left ───────────────────
    tl.to(lsPlane, { x: -1750, duration: 1.2, ease: 'power1.inOut' }, 1.1);

    // ── 1.15s: F-22 climbs diagonally ───────────────────────
    tl.to(lsF22, { x: 780, y: -820, rotation: -50, duration: 1.3, ease: 'power2.inOut' }, 1.15);
    tl.to('#ls-f22 ellipse:last-of-type, #ls-f22 ellipse:nth-of-type(2)', {
      scaleY: 1.5, transformOrigin: '50% 0%', duration: 0.16, repeat: 8, yoyo: true, ease: 'none',
    }, 1.15);

    // ── 1.2s: UFO #1 descends ───────────────────────────────
    tl.to(lsShipGrp, { y: 250, duration: 0.75, ease: 'back.out(1.1)' }, 1.2);

    // ── 1.35s: UFO #2 scout descends left ───────────────────
    tl.to(lsUfo2, { y: 240, duration: 0.7, ease: 'back.out(1.2)' }, 1.35);

    // ── 1.4s: Mothership descends top-center ────────────────
    tl.to(lsMothership, { y: 200, duration: 0.9, ease: 'back.out(1.05)' }, 1.4);

    // ── 1.5s: Bio-ship drifts in top-right ──────────────────
    tl.to(lsBioship, { y: 180, duration: 0.9, ease: 'back.out(1.1)' }, 1.5);

    // ── 1.6s: Rocket #3 enters from far right ───────────────
    tl.to(lsRocket3, { x: -1260, y: -220, rotation: 130, duration: 1.2, ease: 'power2.in' }, 1.6);
    tl.to('#ls-rocket3-flame', { scaleY: 1.7, scaleX: 1.3, transformOrigin: '50% 0%', duration: 0.13, repeat: 9, yoyo: true, ease: 'none' }, 1.6);

    // ── 1.7s: Akira motorcycle SLIDES through bottom ─────────
    tl.to(lsAkira, { x: -1760, duration: 0.95, ease: 'power3.in' }, 1.7);
    tl.call(() => {
      for (let i = 0; i < 6; i++)
        setTimeout(() => spawnSmoke(80 - i * 11, 84 + Math.random() * 4, 'rgba(34,211,238,0.1)'), i * 80);
    }, [], 1.75);

    // ── 1.85s: UFO #1 fires laser volley ────────────────────
    tl.to(lsShipLasers, { opacity: 1, duration: 0.06 }, 1.85);
    tl.to('.ls-ship-laser', { attr: { height: 680 }, duration: 0.4, ease: 'power3.out', stagger: 0.09 }, 1.85);

    // ── 1.9s: UFO #2 tractor beam ───────────────────────────
    tl.to(lsUfo2Beam, { opacity: 1, duration: 0.3 }, 1.9);
    tl.to(lsUfo2Beam, { opacity: 0, duration: 0.4 }, 2.5);

    // ── 2.0s: KAMEHAMEHA fires from SSJ ─────────────────────
    tl.to(lsKamehameha, { opacity: 1, duration: 0.05 }, 2.0);
    // Funnel + beam grow leftward from SSJ hands ~(900,405)
    tl.fromTo('#ls-kame-beam', { attr: { x: 900, width: 0 } }, { attr: { x: 0, width: 900 }, duration: 0.35, ease: 'power3.out' }, 2.0);
    tl.fromTo('#ls-kame-glow', { attr: { x: 900, width: 0 } }, { attr: { x: 0, width: 900 }, duration: 0.35, ease: 'power3.out' }, 2.0);
    tl.fromTo('#ls-kame-shape', { attr: { points: '900,398 900,412 900,408 900,402' } },
      { attr: { points: '900,392 900,418 0,410 0,400' }, duration: 0.35, ease: 'power3.out' }, 2.0);
    tl.to(lsKamehameha, { opacity: 0, duration: 0.4 }, 2.5);

    // ── 2.1s: Spirit Bomb drops from sky ────────────────────
    tl.to(lsSpiritBomb, { y: 560, duration: 0.85, ease: 'power2.in' }, 2.1);
    tl.to('#ls-sb-core',  { attr: { r: 55 }, duration: 0.6, ease: 'power1.out' }, 2.1);
    tl.to('#ls-sb-ring1', { attr: { r: 72 }, duration: 0.6, ease: 'power1.out' }, 2.1);
    tl.to('#ls-sb-ring2', { attr: { r: 86 }, duration: 0.6, ease: 'power1.out' }, 2.1);
    tl.to('#ls-sb-ring3', { attr: { r: 98 }, duration: 0.6, ease: 'power1.out' }, 2.1);

    // ── 2.25s: Mothership charges + fires planet buster ──────
    tl.to(lsCannonGlow, { opacity: 0.9, duration: 0.25, ease: 'power3.in' }, 2.25);
    tl.to(lsPlanetBeam, { opacity: 1, duration: 0.05 }, 2.5);
    tl.fromTo('#ls-pb-beam', { attr: { height: 0 } }, { attr: { height: 620 }, duration: 0.35, ease: 'power3.out' }, 2.5);
    tl.fromTo('#ls-pb-core', { attr: { height: 0 } }, { attr: { height: 620 }, duration: 0.35, ease: 'power3.out' }, 2.5);
    tl.to(lsPlanetBeam, { opacity: 0, duration: 0.3 }, 3.0);
    tl.to(lsCannonGlow, { opacity: 0, duration: 0.3 }, 3.0);

    // ── 2.4s: EXPLOSION CASCADE ──────────────────────────────
    lsExps.forEach((exp, i) => {
      tl.fromTo(exp,
        { attr: { r: 0 }, opacity: 1 },
        { attr: { r: 75 + i * 12 }, opacity: 0, duration: 0.65, ease: 'power2.out' },
      2.4 + i * 0.08);
    });
    // Smoke bursts for explosions
    tl.call(() => {
      const spots = [[36,46],[61,34],[47,63],[72,54],[26,32],[82,68],[17,40],[65,80]];
      spots.forEach(([x, y], i) => {
        setTimeout(() => {
          spawnSmoke(x + Math.random()*4, y + Math.random()*4, 'rgba(255,120,0,0.15)');
          spawnSmoke(x - 2, y - 2, 'rgba(255,200,50,0.1)');
        }, i * 90);
      });
    }, [], 2.4);

    // ── 2.6s: MANGA SPEED LINES flash ───────────────────────
    tl.to(lsSpeedlines, { opacity: 0.85, duration: 0.08 }, 2.6);
    tl.to(lsSpeedlines, { opacity: 0,    duration: 0.25 }, 2.7);

    // ── 2.65s: MEGA CENTRAL EXPLOSION + flash ────────────────
    tl.fromTo(lsMegaExp, { attr: { r: 0 }, opacity: 0.9 },
      { attr: { r: 380 }, opacity: 0, duration: 1.0, ease: 'power2.out' }, 2.65);
    tl.to(lsFlash, { opacity: 0.98, duration: 0.12, ease: 'power4.in' }, 2.68);
    tl.to(lsFlash, { opacity: 0,    duration: 0.55, ease: 'power2.out' }, 2.8);
    // Screen shake
    tl.to('#ls-scene', { x: 8, duration: 0.05, yoyo: true, repeat: 9, ease: 'none' }, 2.65);

    // ── 2.7s: UFO lasers fade ────────────────────────────────
    tl.to(lsShipLasers, { opacity: 0, duration: 0.15 }, 2.7);

    // ── 2.8s: "POWER LEVEL: OVER 9000!!" flashes in ──────────
    tl.to(lsOver9000, { attr: { 'font-size': 38 }, opacity: 1, duration: 0.12, ease: 'power3.out' }, 2.8);
    tl.to(lsOver9000, { opacity: 0, duration: 0.08, repeat: 5, yoyo: true, ease: 'none' }, 3.1);
    tl.set(lsOver9000, { opacity: 0 }, 3.45);

    // ── 2.9s: OPM THE PUNCH ─────────────────────────────────
    tl.to(lsOpm, { x: 40, duration: 0.12, ease: 'power4.out' }, 2.9);  // lunge forward
    tl.to(lsOpmRings, { opacity: 1, duration: 0.05 }, 2.9);
    const opmRingEls = document.querySelectorAll('.ls-opm-ring');
    opmRingEls.forEach((r, i) => {
      tl.fromTo(r, { attr: { r: 0 }, opacity: 1 },
        { attr: { r: 120 + i * 40 }, opacity: 0, duration: 0.7, ease: 'power2.out' },
      2.9 + i * 0.06);
    });
    // OPM shockwave mega ring
    tl.fromTo(lsOpmMega, { attr: { r: 0 }, opacity: 0.8 },
      { attr: { r: 500 }, opacity: 0, duration: 1.2, ease: 'power2.out' }, 2.9);
    // Secondary flash from the punch
    tl.to(lsFlash, { opacity: 0.6, duration: 0.08 }, 2.92);
    tl.to(lsFlash, { opacity: 0,   duration: 0.3  }, 3.0);

    // ── 3.1s: SSJ final aura burst then scatter ──────────────
    tl.to('.ls-ssj-aura', { opacity: 0.9, scaleX: 1.4, scaleY: 1.6, duration: 0.15, transformOrigin: '50% 50%' }, 3.1);

    // ── 3.3s: Title flicker off ──────────────────────────────
    tl.to(lsTitle, { opacity: 0, duration: 0.08, repeat: 5, yoyo: true, ease: 'none' }, 3.3);
    tl.set(lsTitle, { opacity: 0 }, 3.65);

    // ── 3.5s: EVERYTHING SCATTERS ───────────────────────────
    tl.to(lsRobot,      { y: 300,  opacity: 0, duration: 0.45, ease: 'power3.in' }, 3.5);
    tl.to(lsSaiyan,     { y: -500, x: 200, opacity: 0, duration: 0.5, ease: 'power3.in' }, 3.5);
    tl.to(lsOpm,        { y: -480, x: -150, opacity: 0, duration: 0.45, ease: 'power3.in' }, 3.52);
    tl.to(lsMothership, { y: -350, opacity: 0, duration: 0.4, ease: 'power2.in' }, 3.5);
    tl.to(lsShipGrp,    { y: -280, opacity: 0, duration: 0.4, ease: 'power2.in' }, 3.52);
    tl.to(lsBioship,    { x: 300, y: -250, opacity: 0, duration: 0.4, ease: 'power2.in' }, 3.5);
    tl.to(lsPlanet,     { x: -400, y: 900, opacity: 0, duration: 0.6, ease: 'power2.in' }, 3.5);
    tl.to(lsSpiritBomb, { y: 200, opacity: 0, duration: 0.3 }, 3.5);
    tl.to(lsUfo2,       { y: -250, opacity: 0, duration: 0.4 }, 3.55);

    // Timeline ends ~4.2s → 0.55s fade → total ~4.75s
  })();

  function showModalDirectly(snippetEl: HTMLElement) {
    gsap.to(snippetEl, { opacity: 0.1, duration: 0.15 });
    document.body.style.overflow = 'hidden';
    overlay.classList.add('visible');
    overlay.style.opacity = '1';
    modal.style.opacity = '1';
    modal.style.transform = 'scale(1)';
  }

  function openModal(snippetEl: HTMLElement, meta: { name: string; pattern: string; description: string; code: string }) {
    if (isModalOpen) return;
    isModalOpen = true;
    activeSnippetEl = snippetEl;

    // Populate content
    modalBadge.textContent = meta.pattern;
    modalTitle.textContent = meta.name;
    modalDesc.textContent = meta.description;
    modalCode.innerHTML = highlightPython(meta.code);

    // Skip elaborate animations for reduced motion
    if (prefersReducedMotion) {
      showModalDirectly(snippetEl);
      return;
    }

    // Get snippet position for flying clone
    const rect = snippetEl.getBoundingClientRect();

    // Step 1: Shake the snippet
    const shakeTl = gsap.timeline();
    shakeTl.to(snippetEl, { x: -6, duration: 0.05, ease: 'power2.inOut' })
      .to(snippetEl, { x: 6, duration: 0.05, ease: 'power2.inOut' })
      .to(snippetEl, { x: -4, duration: 0.05, ease: 'power2.inOut' })
      .to(snippetEl, { x: 4, duration: 0.05, ease: 'power2.inOut' })
      .to(snippetEl, { x: 0, duration: 0.05, ease: 'power2.inOut' });

    // Step 2: Glow bright
    shakeTl.to(snippetEl, {
      color: 'rgba(74, 222, 128, 0.9)',
      textShadow: '0 0 30px rgba(74, 222, 128, 0.6), 0 0 60px rgba(74, 222, 128, 0.3)',
      duration: 0.2,
      ease: 'power2.out',
    }, '-=0.1');

    // Step 3: Create flying clone
    shakeTl.call(() => {
      const clone = snippetEl.cloneNode(true) as HTMLElement;
      clone.style.cssText = `
        position: fixed;
        top: ${rect.top}px;
        left: ${rect.left}px;
        width: ${rect.width}px;
        font-family: 'JetBrains Mono', 'Fira Code', monospace;
        font-size: 11px;
        line-height: 1.5;
        color: rgba(74, 222, 128, 0.9);
        text-shadow: 0 0 30px rgba(74, 222, 128, 0.6), 0 0 60px rgba(74, 222, 128, 0.3);
        white-space: pre;
        z-index: 10001;
        pointer-events: none;
      `;
      document.body.appendChild(clone);

      // Fade original
      gsap.to(snippetEl, { opacity: 0.1, duration: 0.3 });

      // Animate clone to center
      const centerX = window.innerWidth / 2 - rect.width / 2;
      const centerY = window.innerHeight / 2 - rect.height / 2;

      gsap.to(clone, {
        top: centerY,
        left: centerX,
        scale: 1.5,
        opacity: 0,
        duration: 0.5,
        ease: 'power3.in',
        onComplete: () => {
          clone.remove();

          // Lock scroll
          document.body.style.overflow = 'hidden';

          // Show overlay + modal
          overlay.classList.add('visible');
          gsap.fromTo(overlay, { opacity: 0 }, { opacity: 1, duration: 0.3, ease: 'power2.out' });
          gsap.fromTo(modal, { scale: 0.8, opacity: 0 }, {
            scale: 1,
            opacity: 1,
            duration: 0.5,
            ease: 'back.out(1.7)',
          });
        }
      });
    });
  }

  function closeModal() {
    if (!isModalOpen) return;

    const restoreState = () => {
      overlay.classList.remove('visible');
      document.body.style.overflow = '';
      isModalOpen = false;

      if (activeSnippetEl) {
        if (prefersReducedMotion) {
          activeSnippetEl.style.opacity = '0.8';
          activeSnippetEl.style.color = 'rgba(74, 222, 128, 0.25)';
          activeSnippetEl.style.textShadow = 'none';
        } else {
          gsap.to(activeSnippetEl, {
            opacity: 0.8,
            color: 'rgba(74, 222, 128, 0.25)',
            textShadow: 'none',
            duration: 0.4,
            ease: 'power2.out',
          });
        }
        activeSnippetEl = null;
      }
    };

    if (prefersReducedMotion) {
      restoreState();
      return;
    }

    const tl = gsap.timeline({ onComplete: restoreState });
    tl.to(modal, { scale: 0.85, opacity: 0, duration: 0.3, ease: 'power2.in' });
    tl.to(overlay, { opacity: 0, duration: 0.2, ease: 'power2.in' }, '-=0.15');
  }

  // Close triggers
  modalClose.addEventListener('click', closeModal);
  overlay.addEventListener('click', (e) => {
    if (e.target === overlay) closeModal();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && isModalOpen) closeModal();
  });

  // Inject snippets into each section as absolute-positioned children
  const allCodeBlocks: HTMLElement[] = [];

  Object.entries(sectionSnippets).forEach(([selector, snippets]) => {
    const section = document.querySelector(selector) as HTMLElement;
    if (!section) return;

    // Ensure section has relative positioning for absolute children
    const computedPos = getComputedStyle(section).position;
    if (computedPos === 'static') {
      section.style.position = 'relative';
    }

    snippets.forEach((s, i) => {
      const el = document.createElement('div');
      el.className = 'floating-code code-float';
      el.setAttribute('role', 'button');
      el.setAttribute('tabindex', '0');
      el.setAttribute('aria-label', `View solution: ${s.name}`);
      el.textContent = s.code;
      let style = `position: absolute; top: ${s.top}; transform: rotate(${s.rotate}); opacity: 0; z-index: 1; pointer-events: auto;`;
      if (s.left) style += ` left: ${s.left};`;
      if (s.right) style += ` right: ${s.right};`;
      el.style.cssText = style;
      section.appendChild(el);
      allCodeBlocks.push(el);

      const handleActivate = () => {
        openModal(el, { name: s.name, pattern: s.pattern, description: s.description, code: s.code });
      };

      el.addEventListener('click', handleActivate);
      el.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          handleActivate();
        }
      });

      // Set initial state for batch animation
      if (prefersReducedMotion) {
        el.style.opacity = '0.8';
      } else {
        gsap.set(el, { opacity: 0 });
      }
    });
  });

  // Batch all floating code snippet fade-ins into one ScrollTrigger
  if (!prefersReducedMotion && allCodeBlocks.length > 0) {
    ScrollTrigger.batch('.floating-code', {
      start: 'top 80%',
      onEnter: (batch) => gsap.to(batch, { opacity: 0.8, duration: 0.8, stagger: 0.12, ease: 'power2.out' }),
      once: true,
    });
  }

  // Parallax background layers — single timeline with one ScrollTrigger
  if (!prefersReducedMotion) {
    const deepLayer = document.getElementById('parallax-deep');
    const midLayer = document.getElementById('parallax-mid');

    if (deepLayer && midLayer) {
      const parallaxTl = gsap.timeline({
        scrollTrigger: {
          trigger: 'body',
          start: 'top top',
          end: 'bottom bottom',
          scrub: 1,
        }
      });
      parallaxTl.to(deepLayer, { yPercent: -15, ease: 'none' }, 0);
      parallaxTl.to(midLayer, { yPercent: -30, ease: 'none' }, 0);
    }
  }

  // Section reveals — batched
  const sections = document.querySelectorAll('.section-reveal');
  if (prefersReducedMotion) {
    sections.forEach((section) => {
      (section as HTMLElement).style.opacity = '1';
      (section as HTMLElement).style.transform = 'none';
    });
  } else {
    gsap.set('.section-reveal', { opacity: 0, y: 60 });
    ScrollTrigger.batch('.section-reveal', {
      start: 'top 85%',
      onEnter: (batch) => gsap.to(batch, { opacity: 1, y: 0, duration: 1, stagger: 0.15, ease: 'power3.out' }),
      once: true,
    });
  }

  // Mouse interaction: activate code blocks on proximity (optimized, skip for reduced motion)
  if (!prefersReducedMotion) {
    // Track visible code blocks with IntersectionObserver
    const visibleBlocks = new Set<HTMLElement>();
    const visObserver = new IntersectionObserver((entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) visibleBlocks.add(entry.target as HTMLElement);
        else visibleBlocks.delete(entry.target as HTMLElement);
      });
    }, { rootMargin: '100px' });
    allCodeBlocks.forEach((block) => visObserver.observe(block));

    // Cache rects and invalidate on scroll/resize (debounced)
    let cachedRects: Map<HTMLElement, DOMRect> = new Map();
    let rectsDirty = true;
    let rectsDebounceTimer = 0;

    const invalidateRectsDebounced = () => {
      if (rectsDebounceTimer) clearTimeout(rectsDebounceTimer);
      rectsDebounceTimer = window.setTimeout(() => { rectsDirty = true; }, 150);
    };
    window.addEventListener('scroll', invalidateRectsDebounced, { passive: true });
    window.addEventListener('resize', () => { rectsDirty = true; }, { passive: true });

    // Pause during scroll
    let isScrolling = false;
    let scrollIdleTimer = 0;
    window.addEventListener('scroll', () => {
      isScrolling = true;
      if (scrollIdleTimer) clearTimeout(scrollIdleTimer);
      scrollIdleTimer = window.setTimeout(() => { isScrolling = false; }, 150);
    }, { passive: true });

    function updateRectCache() {
      if (!rectsDirty) return;
      cachedRects.clear();
      visibleBlocks.forEach((block) => {
        cachedRects.set(block, block.getBoundingClientRect());
      });
      rectsDirty = false;
    }

    let mouseMoveRaf = 0;
    document.addEventListener('mousemove', (e) => {
      if (mouseMoveRaf || isScrolling) return;
      mouseMoveRaf = requestAnimationFrame(() => {
        mouseMoveRaf = 0;
        updateRectCache();

        visibleBlocks.forEach((block) => {
          const rect = cachedRects.get(block);
          if (!rect) return;
          const blockCenterX = rect.left + rect.width / 2;
          const blockCenterY = rect.top + rect.height / 2;
          const dist = Math.hypot(e.clientX - blockCenterX, e.clientY - blockCenterY);

          if (dist < 200) {
            block.classList.add('activated');
            const angle = Math.atan2(blockCenterY - e.clientY, blockCenterX - e.clientX);
            const push = Math.max(0, (200 - dist) / 200) * 8;
            gsap.to(block, {
              x: Math.cos(angle) * push,
              y: Math.sin(angle) * push,
              duration: 0.4,
              ease: 'power2.out',
            });
          } else {
            block.classList.remove('activated');
            gsap.to(block, {
              x: 0,
              y: 0,
              duration: 0.8,
              ease: 'power2.out',
            });
          }
        });
      });
    });
  }
</script>
