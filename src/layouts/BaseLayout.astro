<style is:global>
  :root {
    --font-heading: 'Plus Jakarta Sans', 'Outfit', system-ui, sans-serif;
    --font-display: 'Outfit', 'Plus Jakarta Sans', system-ui, sans-serif;
    --font-organic: 'Cormorant Garamond', Georgia, serif;
    --font-mono: 'JetBrains Mono', 'Fira Code', monospace;
    --font-sans: 'Plus Jakarta Sans', system-ui, sans-serif;
  }

  body {
    font-family: var(--font-sans);
  }

  h1, h2, h3, h4, h5, h6 {
    font-family: var(--font-heading);
  }

  @media print {
    body {
      background: white;
      font-size: 11pt;
    }
    .no-print {
      display: none !important;
    }
    .print-break {
      page-break-before: always;
    }
  }

  /* ── Loading Screen ─────────────────────────────────── */
  #loading-screen {
    position: fixed;
    inset: 0;
    z-index: 99999;
    background: #020a04;
    overflow: hidden;
  }

  #ls-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 60% at 50% 70%, #071a09 0%, #020a04 65%),
      radial-gradient(ellipse 40% 30% at 75% 20%, #0a0520 0%, transparent 60%);
  }

  #ls-stars-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #ls-scene {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }

  #ls-smoke-container {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .ls-smoke {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    animation: ls-smoke-rise 1.8s ease-out forwards;
  }

  @keyframes ls-smoke-rise {
    0%   { transform: scale(0.4) translateY(0px);   opacity: 0.6; }
    60%  { opacity: 0.3; }
    100% { transform: scale(3.0) translateY(-70px); opacity: 0; }
  }

  #ls-flash {
    position: absolute;
    inset: 0;
    background: white;
    opacity: 0;
    pointer-events: none;
  }

  #ls-title {
    position: absolute;
    bottom: 11%;
    left: 50%;
    transform: translateX(-50%);
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: clamp(12px, 1.8vw, 18px);
    color: #4ade80;
    letter-spacing: 0.4em;
    text-shadow:
      0 0 18px rgba(74, 222, 128, 0.7),
      0 0 40px rgba(74, 222, 128, 0.3);
    opacity: 0;
    white-space: nowrap;
  }

  /* SSJ aura ellipses pulse */
  .ls-ssj-aura {
    animation: ls-aura-pulse 0.28s ease-in-out infinite alternate;
  }
  @keyframes ls-aura-pulse {
    from { opacity: 0;    transform: scaleX(0.95) scaleY(0.97); }
    to   { opacity: 0.45; transform: scaleX(1.05) scaleY(1.03); }
  }
  .ls-ssj-bolt {
    animation: ls-bolt-flicker 0.18s steps(2) infinite;
  }
  @keyframes ls-bolt-flicker {
    from { opacity: 0.8; }
    to   { opacity: 0;   }
  }

  /* UFO scout light blink */
  .ls-ufo2-light {
    animation: ls-light-blink 0.35s steps(2) infinite;
  }
  @keyframes ls-light-blink {
    from { opacity: 1;   }
    to   { opacity: 0.1; }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  // Section-scoped floating code snippets — Python3 LeetCode solutions
  interface Snippet {
    code: string;
    top: string;
    left?: string;
    right?: string;
    rotate: string;
    name: string;
    pattern: string;
    description: string;
  }
  const sectionSnippets: Record<string, Snippet[]> = {
    '#hero': [
      { code: '# Two Sum\ndef twoSum(nums, target):\n    seen = {}\n    for i, n in enumerate(nums):\n        if target - n in seen:\n            return [seen[target-n], i]\n        seen[n] = i', top: '10%', left: '3%', rotate: '-2deg', name: 'Two Sum', pattern: 'Hash Map', description: 'Use a hash map to store each number\'s index. For every element, check if the complement (target minus current) already exists in the map. Runs in O(n) time.' },
      { code: '# Valid Parentheses\ndef isValid(s):\n    stack, m = [], {")":"(","]":"[","}":"{"}\n    for c in s:\n        if c in m:\n            if not stack or stack.pop() != m[c]:\n                return False\n        else: stack.append(c)\n    return not stack', top: '15%', right: '5%', rotate: '1deg', name: 'Valid Parentheses', pattern: 'Stack', description: 'Push opening brackets onto a stack. When a closing bracket appears, pop and check it matches. The string is valid if the stack is empty at the end.' },
      { code: '# Best Time Buy Sell Stock\ndef maxProfit(prices):\n    mn, mx = float("inf"), 0\n    for p in prices:\n        mn = min(mn, p)\n        mx = max(mx, p - mn)\n    return mx', top: '45%', left: '55%', rotate: '-1deg', name: 'Best Time to Buy & Sell Stock', pattern: 'Greedy', description: 'Track the minimum price seen so far and the maximum profit at each step. A single pass yields the optimal buy-sell pair in O(n).' },
      { code: '# Climbing Stairs\ndef climbStairs(n):\n    a, b = 1, 1\n    for _ in range(n - 1):\n        a, b = b, a + b\n    return b', top: '60%', right: '60%', rotate: '2deg', name: 'Climbing Stairs', pattern: 'DP', description: 'The number of ways to reach step n is the sum of ways to reach n-1 and n-2, forming a Fibonacci sequence. O(n) time, O(1) space.' },
      { code: '# Contains Duplicate\ndef containsDuplicate(nums):\n    return len(nums) != len(set(nums))', top: '75%', left: '20%', rotate: '-1deg', name: 'Contains Duplicate', pattern: 'Hash Set', description: 'Convert the array to a set and compare lengths. If they differ, a duplicate exists. Elegant one-liner running in O(n) average time.' },
      { code: '# Maximum Subarray - Kadane\ndef maxSubArray(nums):\n    cur = best = nums[0]\n    for n in nums[1:]:\n        cur = max(n, cur + n)\n        best = max(best, cur)\n    return best', top: '30%', right: '25%', rotate: '1deg', name: 'Maximum Subarray', pattern: 'Kadane\'s', description: 'Kadane\'s algorithm: at each position decide whether to extend the current subarray or start fresh. Tracks the running and global max in a single O(n) pass.' },
    ],
    '#experience': [
      { code: '# Merge Two Sorted Lists\ndef mergeTwoLists(l1, l2):\n    if not l1: return l2\n    if not l2: return l1\n    if l1.val < l2.val:\n        l1.next = mergeTwoLists(l1.next, l2)\n        return l1\n    l2.next = mergeTwoLists(l1, l2.next)\n    return l2', top: '5%', left: '4%', rotate: '-2deg', name: 'Merge Two Sorted Lists', pattern: 'Recursion', description: 'Recursively pick the smaller head node and link its next to the merged result of the remaining lists. Classic divide-and-conquer on linked lists.' },
      { code: '# Reverse Linked List\ndef reverseList(head):\n    prev = None\n    while head:\n        nxt = head.next\n        head.next = prev\n        prev = head\n        head = nxt\n    return prev', top: '20%', right: '6%', rotate: '1deg', name: 'Reverse Linked List', pattern: 'Linked List', description: 'Iteratively reverse pointers by maintaining a previous node reference. Each node\'s next pointer is redirected backwards. O(n) time, O(1) space.' },
      { code: '# Binary Search\ndef search(nums, target):\n    lo, hi = 0, len(nums) - 1\n    while lo <= hi:\n        mid = (lo + hi) // 2\n        if nums[mid] == target: return mid\n        elif nums[mid] < target: lo = mid + 1\n        else: hi = mid - 1\n    return -1', top: '40%', left: '50%', rotate: '-1deg', name: 'Binary Search', pattern: 'Binary Search', description: 'Halve the search space each iteration by comparing the middle element to the target. The quintessential O(log n) algorithm for sorted arrays.' },
      { code: '# Product Except Self\ndef productExceptSelf(nums):\n    n = len(nums)\n    ans = [1] * n\n    pre = 1\n    for i in range(n):\n        ans[i] = pre\n        pre *= nums[i]\n    post = 1\n    for i in range(n-1,-1,-1):\n        ans[i] *= post\n        post *= nums[i]\n    return ans', top: '55%', right: '55%', rotate: '2deg', name: 'Product of Array Except Self', pattern: 'Prefix/Suffix', description: 'Build prefix products in a forward pass, then multiply by suffix products in a backward pass. Avoids division and runs in O(n) with O(1) extra space.' },
      { code: '# Valid Palindrome\ndef isPalindrome(s):\n    s = [c.lower() for c in s if c.isalnum()]\n    return s == s[::-1]', top: '75%', left: '15%', rotate: '-1deg', name: 'Valid Palindrome', pattern: 'Two Pointer', description: 'Filter out non-alphanumeric characters, lowercase everything, then check if the sequence reads the same forwards and backwards.' },
      { code: '# 3Sum\ndef threeSum(nums):\n    nums.sort()\n    res = []\n    for i in range(len(nums)-2):\n        if i and nums[i]==nums[i-1]: continue\n        lo, hi = i+1, len(nums)-1\n        while lo < hi:\n            s = nums[i]+nums[lo]+nums[hi]\n            if s < 0: lo += 1\n            elif s > 0: hi -= 1\n            else:\n                res.append([nums[i],nums[lo],nums[hi]])\n                lo += 1\n                while lo<hi and nums[lo]==nums[lo-1]: lo+=1\n    return res', top: '10%', right: '30%', rotate: '1deg', name: '3Sum', pattern: 'Two Pointer', description: 'Sort the array, fix one element, then use two pointers to find pairs that sum to its negation. Skip duplicates to avoid repeated triplets. O(n\u00b2) time.' },
    ],
    '#skills': [
