---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark" style="color-scheme: dark;">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#0a0f0a" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,200..800;1,200..800&family=Outfit:wght@100..900&family=Cormorant+Garamond:ital,wght@0,300..700;1,300..700&family=JetBrains+Mono:wght@100..800&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen bg-background antialiased overflow-x-hidden">
    <!-- Skip to main content -->
    <a href="#main" class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-[99999] focus:px-4 focus:py-2 focus:bg-primary focus:text-primary-foreground focus:rounded-md focus:text-sm focus:font-semibold">
      Skip to main content
    </a>

    <noscript><style>#loading-screen { display: none !important; }</style></noscript>

    <!-- Loading Screen -->
    <div id="loading-screen" aria-hidden="true" role="presentation">
      <div id="ls-bg"></div>
      <canvas id="ls-stars-canvas"></canvas>
      <svg id="ls-scene" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <filter id="ls-glow-green" x="-80%" y="-80%" width="360%" height="360%">
            <feGaussianBlur stdDeviation="5" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
          <filter id="ls-glow-purple" x="-80%" y="-80%" width="360%" height="360%">
            <feGaussianBlur stdDeviation="5" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
          <filter id="ls-glow-cyan" x="-80%" y="-80%" width="360%" height="360%">
            <feGaussianBlur stdDeviation="5" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
          <filter id="ls-glow-gold" x="-80%" y="-80%" width="360%" height="360%">
            <feGaussianBlur stdDeviation="6" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
          <filter id="ls-glow-white" x="-80%" y="-80%" width="360%" height="360%">
            <feGaussianBlur stdDeviation="8" result="blur"/>
            <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
          </filter>
        </defs>

        <!-- ══ PLANET / MOON (lower-left, rises into battle) ══ -->
        <g id="ls-planet" transform="translate(-220, 850)">
          <circle cx="0" cy="0" r="190" fill="#0d0820" stroke="#c084fc" stroke-width="3"/>
          <circle cx="-65" cy="-45" r="30" fill="none" stroke="#c084fc" stroke-width="1.5" opacity="0.55"/>
          <circle cx="75" cy="35" r="22" fill="none" stroke="#c084fc" stroke-width="1.5" opacity="0.45"/>
          <circle cx="-30" cy="85" r="16" fill="none" stroke="#c084fc" stroke-width="1" opacity="0.35"/>
          <circle cx="95" cy="-65" r="13" fill="none" stroke="#c084fc" stroke-width="1" opacity="0.4"/>
          <ellipse cx="0" cy="0" rx="190" ry="55" fill="none" stroke="#c084fc" stroke-width="0.8" opacity="0.2"/>
          <ellipse cx="0" cy="0" rx="190" ry="125" fill="none" stroke="#c084fc" stroke-width="0.8" opacity="0.15"/>
          <!-- Saturn ring -->
          <ellipse cx="0" cy="0" rx="280" ry="45" fill="none" stroke="#c084fc" stroke-width="2" opacity="0.6"/>
          <ellipse cx="0" cy="0" rx="258" ry="40" fill="none" stroke="#f472b6" stroke-width="1" opacity="0.3"/>
        </g>

        <!-- ══ ALIEN MOTHERSHIP (massive, top-center descends) ══ -->
        <g id="ls-mothership" transform="translate(600, -180)">
          <polygon points="0,-90 200,30 160,75 -160,75 -200,30" fill="#070714" stroke="#f472b6" stroke-width="2.5"/>
          <!-- Structural ribs -->
          <line x1="-160" y1="60" x2="-80" y2="-60" stroke="#f472b6" stroke-width="1" opacity="0.4"/>
          <line x1="160" y1="60" x2="80" y2="-60" stroke="#f472b6" stroke-width="1" opacity="0.4"/>
          <line x1="0" y1="-90" x2="-120" y2="60" stroke="#f472b6" stroke-width="0.8" opacity="0.25"/>
          <line x1="0" y1="-90" x2="120" y2="60" stroke="#f472b6" stroke-width="0.8" opacity="0.25"/>
          <!-- Hull detail lines -->
          <line x1="-155" y1="50" x2="155" y2="50" stroke="#f472b6" stroke-width="1" opacity="0.3"/>
          <line x1="-120" y1="20" x2="120" y2="20" stroke="#f472b6" stroke-width="0.8" opacity="0.25"/>
          <!-- Window row -->
          <circle cx="-100" cy="55" r="7" fill="#22d3ee" opacity="0.9" filter="url(#ls-glow-cyan)"/>
          <circle cx="-60" cy="62" r="7" fill="#22d3ee" opacity="0.9" filter="url(#ls-glow-cyan)"/>
          <circle cx="-20" cy="66" r="7" fill="#22d3ee" opacity="0.9" filter="url(#ls-glow-cyan)"/>
          <circle cx="20" cy="66" r="7" fill="#22d3ee" opacity="0.9" filter="url(#ls-glow-cyan)"/>
          <circle cx="60" cy="62" r="7" fill="#22d3ee" opacity="0.9" filter="url(#ls-glow-cyan)"/>
          <circle cx="100" cy="55" r="7" fill="#22d3ee" opacity="0.9" filter="url(#ls-glow-cyan)"/>
          <!-- Bridge tower -->
          <rect x="-28" y="-90" width="56" height="38" rx="5" fill="#07071a" stroke="#c084fc" stroke-width="1.5"/>
          <!-- Wing engines -->
          <ellipse cx="-175" cy="38" rx="28" ry="11" fill="#07071a" stroke="#c084fc" stroke-width="1.5"/>
          <ellipse cx="175" cy="38" rx="28" ry="11" fill="#07071a" stroke="#c084fc" stroke-width="1.5"/>
          <!-- Engine glow -->
          <ellipse cx="-175" cy="48" rx="20" ry="6" fill="#c084fc" opacity="0.4"/>
          <ellipse cx="175" cy="48" rx="20" ry="6" fill="#c084fc" opacity="0.4"/>
          <!-- Planet-buster cannon barrel -->
          <rect x="-12" y="75" width="24" height="55" rx="4" fill="#0d001a" stroke="#f472b6" stroke-width="2"/>
          <circle cx="0" cy="130" r="12" fill="#f472b6" opacity="0" id="ls-cannon-glow" filter="url(#ls-glow-purple)"/>
          <!-- Planet buster beam (in local space) -->
          <g id="ls-planet-beam" opacity="0">
            <rect x="-10" y="130" width="20" height="0" fill="#f472b6" filter="url(#ls-glow-purple)" rx="2" id="ls-pb-beam"/>
            <rect x="-5" y="130" width="10" height="0" fill="white" rx="1" id="ls-pb-core"/>
          </g>
        </g>

        <!-- ══ BIO-ALIEN SHIP / ORGANIC TERROR (top-right) ══ -->
        <g id="ls-bioship" transform="translate(1120, -100)">
          <path d="M 0,-55 C 65,-42 85,5 62,48 C 38,88 -38,88 -62,48 C -85,5 -65,-42 0,-55 Z"
                fill="#0a1a05" stroke="#4ade80" stroke-width="2.5" stroke-linejoin="round"/>
          <!-- Organic inner detail -->
          <path d="M 0,-35 C 40,-25 50,5 35,35 C 20,55 -20,55 -35,35 C -50,5 -40,-25 0,-35 Z"
                fill="none" stroke="#4ade80" stroke-width="1" opacity="0.4"/>
          <!-- Tentacles -->
          <path d="M -55,35 C -80,58 -88,90 -65,125" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round"/>
          <path d="M 55,35 C 80,58 88,90 65,125" fill="none" stroke="#4ade80" stroke-width="3" stroke-linecap="round"/>
          <path d="M -30,62 C -42,88 -35,118 -12,138" fill="none" stroke="#4ade80" stroke-width="2" stroke-linecap="round"/>
          <path d="M 30,62 C 42,88 35,118 12,138" fill="none" stroke="#4ade80" stroke-width="2" stroke-linecap="round"/>
          <path d="M 0,68 C 5,100 0,130 0,150" fill="none" stroke="#4ade80" stroke-width="2.5" stroke-linecap="round"/>
          <!-- Central eye -->
          <circle cx="0" cy="0" r="20" fill="#0a1a0a" stroke="#4ade80" stroke-width="2.5"/>
          <circle cx="0" cy="0" r="12" fill="#4ade80" opacity="0.85" filter="url(#ls-glow-green)"/>
          <circle cx="-4" cy="-4" r="5" fill="white" opacity="0.5"/>
          <!-- Side eyes -->
          <circle cx="-30" cy="-18" r="9" fill="#4ade80" opacity="0.7"/>
          <circle cx="30" cy="-18" r="9" fill="#4ade80" opacity="0.7"/>
          <circle cx="-30" cy="-18" r="4" fill="white" opacity="0.3"/>
          <circle cx="30" cy="-18" r="4" fill="white" opacity="0.3"/>
        </g>

        <!-- ══ UFO #1 – CLASSIC SAUCER (top-right) ══ -->
        <g id="ls-ship" transform="translate(900, -110)">
          <ellipse cx="0" cy="15" rx="55" ry="10" fill="#c084fc" opacity="0.3"/>
          <ellipse cx="0" cy="0" rx="75" ry="24" fill="#200a3d" stroke="#c084fc" stroke-width="2.5"/>
          <ellipse cx="0" cy="0" rx="62" ry="13" fill="none" stroke="#f472b6" stroke-width="1.2" opacity="0.5"/>
          <path d="M -34 0 Q -34 -36 0 -40 Q 34 -36 34 0 Z" fill="#1a0a30" stroke="#c084fc" stroke-width="1.5"/>
          <path d="M -22 -2 Q -20 -30 0 -35 Q 20 -30 22 -2 Z" fill="#22d3ee" opacity="0.15"/>
          <circle cx="-30" cy="-4" r="6" fill="#22d3ee" opacity="0.9" filter="url(#ls-glow-cyan)"/>
          <circle cx="0" cy="-8" r="6" fill="#22d3ee" opacity="0.9" filter="url(#ls-glow-cyan)"/>
          <circle cx="30" cy="-4" r="6" fill="#22d3ee" opacity="0.9" filter="url(#ls-glow-cyan)"/>
          <g id="ls-ship-lasers" opacity="0">
            <rect class="ls-ship-laser" x="-35" y="24" width="6" height="0" fill="#c084fc" filter="url(#ls-glow-purple)" rx="2"/>
            <rect class="ls-ship-laser" x="-3" y="24" width="6" height="0" fill="#c084fc" filter="url(#ls-glow-purple)" rx="2"/>
            <rect class="ls-ship-laser" x="29" y="24" width="6" height="0" fill="#c084fc" filter="url(#ls-glow-purple)" rx="2"/>
          </g>
        </g>

        <!-- ══ UFO #2 – SCOUT SHIP (left side) ══ -->
        <g id="ls-ufo2" transform="translate(260, -80)">
          <ellipse cx="0" cy="8" rx="44" ry="8" fill="#f472b6" opacity="0.25"/>
          <ellipse cx="0" cy="0" rx="52" ry="17" fill="#150a25" stroke="#f472b6" stroke-width="2"/>
          <path d="M -22 0 Q -22 -24 0 -28 Q 22 -24 22 0 Z" fill="#0a051a" stroke="#f472b6" stroke-width="1.5"/>
          <circle cx="-22" cy="8" r="5" fill="#f472b6" class="ls-ufo2-light"/>
          <circle cx="0" cy="10" r="5" fill="#fbbf24" class="ls-ufo2-light" style="animation-delay:0.13s"/>
          <circle cx="22" cy="8" r="5" fill="#4ade80" class="ls-ufo2-light" style="animation-delay:0.26s"/>
          <g id="ls-ufo2-beam" opacity="0">
            <polygon points="-12,17 12,17 48,170 -48,170" fill="#f472b6" opacity="0.18"/>
            <polygon points="-5,17 5,17 18,170 -18,170" fill="white" opacity="0.1"/>
          </g>
        </g>

        <!-- ══ ROBOT (center, rises from bottom) ══ -->
        <g id="ls-robot" transform="translate(600, 900)">
          <rect x="-28" y="20" width="22" height="32" rx="3" fill="#0d1f0d" stroke="#4ade80" stroke-width="1.5"/>
          <rect x="6" y="20" width="22" height="32" rx="3" fill="#0d1f0d" stroke="#4ade80" stroke-width="1.5"/>
          <rect x="-38" y="-62" width="76" height="82" rx="7" fill="#0d1f0d" stroke="#4ade80" stroke-width="2"/>
          <rect x="-62" y="-52" width="24" height="14" rx="3" fill="#0d1f0d" stroke="#4ade80" stroke-width="1.5"/>
          <rect x="38" y="-52" width="24" height="14" rx="3" fill="#0d1f0d" stroke="#4ade80" stroke-width="1.5"/>
          <rect x="-30" y="-112" width="60" height="52" rx="7" fill="#0d1f0d" stroke="#4ade80" stroke-width="2"/>
          <line x1="0" y1="-112" x2="0" y2="-133" stroke="#4ade80" stroke-width="2.5"/>
          <circle cx="0" cy="-138" r="6" fill="#4ade80" filter="url(#ls-glow-green)"/>
          <circle cx="-12" cy="-90" r="10" fill="#0a0f0a" stroke="#4ade80" stroke-width="2"/>
          <circle cx="12" cy="-90" r="10" fill="#0a0f0a" stroke="#4ade80" stroke-width="2"/>
          <circle class="ls-eye-glow" cx="-12" cy="-90" r="6" fill="#4ade80" filter="url(#ls-glow-green)"/>
          <circle class="ls-eye-glow" cx="12" cy="-90" r="6" fill="#4ade80" filter="url(#ls-glow-green)"/>
          <rect x="-20" y="-75" width="40" height="9" rx="2" fill="#4ade80" opacity="0.35"/>
          <rect x="-24" y="-50" width="48" height="34" rx="4" fill="#0a1a0a" stroke="#4ade80" stroke-width="1" opacity="0.9"/>
          <circle cx="-12" cy="-33" r="5" fill="#4ade80" opacity="0.9"/>
          <circle cx="0" cy="-33" r="5" fill="#22d3ee" opacity="0.9"/>
          <circle cx="12" cy="-33" r="5" fill="#c084fc" opacity="0.9"/>
          <g id="ls-robot-lasers" opacity="0">
            <rect id="ls-laser-l" x="-12" y="-94" width="0" height="8" fill="#4ade80" filter="url(#ls-glow-green)" rx="2"/>
            <rect id="ls-laser-r" x="12" y="-94" width="0" height="8" fill="#4ade80" filter="url(#ls-glow-green)" rx="2"/>
          </g>
        </g>

        <!-- ══ SUPER SAIYAN WARRIOR (right side) ══ -->
        <g id="ls-saiyan" transform="translate(980, 900)">
          <!-- Aura outer -->
          <ellipse class="ls-ssj-aura" cx="0" cy="-65" rx="70" ry="145" fill="none" stroke="#fbbf24" stroke-width="2.5" opacity="0"/>
          <ellipse class="ls-ssj-aura" cx="0" cy="-65" rx="55" ry="118" fill="none" stroke="#fbbf24" stroke-width="1.5" opacity="0"/>
          <ellipse class="ls-ssj-aura" cx="0" cy="-65" rx="42" ry="92" fill="#fbbf24" opacity="0" class="ls-ssj-fill"/>
          <!-- Aura lightning -->
          <polyline class="ls-ssj-bolt" points="-68,-18 -52,-42 -72,-68 -48,-90" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" opacity="0"/>
          <polyline class="ls-ssj-bolt" points="68,-22 52,-48 72,-74 50,-96" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" opacity="0"/>
          <polyline class="ls-ssj-bolt" points="-60,-80 -42,-100 -55,-120" fill="none" stroke="#fbbf24" stroke-width="1.5" stroke-linecap="round" opacity="0"/>
          <polyline class="ls-ssj-bolt" points="60,-85 44,-108 58,-128" fill="none" stroke="#fbbf24" stroke-width="1.5" stroke-linecap="round" opacity="0"/>
          <!-- Legs/boots -->
          <polygon points="-24,22 -6,22 -8,58 -26,58" fill="#1a0a0a" stroke="#fbbf24" stroke-width="1.5"/>
          <polygon points="6,22 24,22 26,58 8,58" fill="#1a0a0a" stroke="#fbbf24" stroke-width="1.5"/>
          <!-- Torso GI -->
          <polygon points="-30,-62 30,-62 34,22 -34,22" fill="#1a0a0a" stroke="#fbbf24" stroke-width="1.5"/>
          <!-- GI V-collar -->
          <polyline points="-14,-62 0,-40 14,-62" fill="none" stroke="#fbbf24" stroke-width="2"/>
          <!-- Belt sash -->
          <rect x="-34" y="-6" width="68" height="9" rx="1" fill="none" stroke="#fbbf24" stroke-width="2"/>
          <!-- Side sash strips -->
          <line x1="-34" y1="5" x2="-34" y2="22" stroke="#fbbf24" stroke-width="1.5"/>
          <line x1="34" y1="5" x2="34" y2="22" stroke="#fbbf24" stroke-width="1.5"/>
          <!-- Left arm – Kamehameha double push -->
          <polygon points="-34,-58 -72,-58 -76,-44 -34,-44" fill="#1a0a0a" stroke="#fbbf24" stroke-width="1.5"/>
          <!-- Left fist -->
          <rect x="-80" y="-62" width="14" height="22" rx="2" fill="#1a0a0a" stroke="#fbbf24" stroke-width="1.5"/>
          <!-- Right arm – same -->
          <polygon points="-34,-40 -72,-40 -76,-26 -34,-26" fill="#1a0a0a" stroke="#fbbf24" stroke-width="1.5"/>
          <rect x="-80" y="-44" width="14" height="22" rx="2" fill="#1a0a0a" stroke="#fbbf24" stroke-width="1.5"/>
          <!-- Head -->
          <ellipse cx="0" cy="-88" rx="23" ry="27" fill="#1a0a0a" stroke="#fbbf24" stroke-width="1.5"/>
          <!-- Eyes – intense -->
          <line x1="-15" y1="-90" x2="-5" y2="-88" stroke="#fbbf24" stroke-width="3.5" stroke-linecap="round"/>
          <line x1="5" y1="-88" x2="15" y2="-90" stroke="#fbbf24" stroke-width="3.5" stroke-linecap="round"/>
          <!-- Angry brows -->
          <line x1="-17" y1="-98" x2="-5" y2="-94" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round"/>
          <line x1="5" y1="-94" x2="17" y2="-98" stroke="#fbbf24" stroke-width="2.5" stroke-linecap="round"/>
          <!-- SUPER SAIYAN HAIR – spiky manga-style -->
          <polygon points="-3,-115 6,-148 -6,-148" fill="#fbbf24"/>
          <polygon points="8,-111 22,-142 10,-136" fill="#fbbf24"/>
          <polygon points="-8,-111 -22,-142 -10,-136" fill="#fbbf24"/>
          <polygon points="16,-105 34,-132 20,-122" fill="#fbbf24"/>
          <polygon points="-16,-105 -34,-132 -20,-122" fill="#fbbf24"/>
          <polygon points="22,-96 42,-118 25,-110" fill="#fbbf24"/>
          <polygon points="-22,-96 -42,-118 -25,-110" fill="#fbbf24"/>
          <!-- Wide base spikes -->
          <polygon points="14,-90 36,-105 20,-96" fill="#fbbf24"/>
          <polygon points="-14,-90 -36,-105 -20,-96" fill="#fbbf24"/>
          <!-- Hair base fill -->
          <path d="M -23,-111 L -22,-96 L 22,-96 L 23,-111 Q 8,-108 0,-115 Q -8,-108 -23,-111 Z" fill="#fbbf24"/>
        </g>

        <!-- ══ ONE PUNCH MAN – SAITAMA (left side) ══ -->
        <g id="ls-opm" transform="translate(165, 900)">
          <!-- Cape flowing back -->
          <path d="M -28,-55 Q -55,10 -52,62 L -18,65 Q -22,10 -12,-52 Z" fill="#1a0820" stroke="#f472b6" stroke-width="1.5" opacity="0.7"/>
          <!-- Boots -->
          <rect x="-24" y="22" width="19" height="38" rx="2" fill="#0a0a1a" stroke="#22d3ee" stroke-width="1.5"/>
          <rect x="5" y="22" width="19" height="38" rx="2" fill="#0a0a1a" stroke="#22d3ee" stroke-width="1.5"/>
          <!-- Suit body -->
          <polygon points="-26,-62 26,-62 30,22 -30,22" fill="#0a0a1a" stroke="#22d3ee" stroke-width="1.5"/>
          <!-- Suit seams -->
          <line x1="-30" y1="-20" x2="30" y2="-20" stroke="#22d3ee" stroke-width="0.8" opacity="0.5"/>
          <line x1="0" y1="-62" x2="0" y2="-20" stroke="#22d3ee" stroke-width="0.8" opacity="0.4"/>
          <!-- Left arm (resting/back) -->
          <rect x="-52" y="-55" width="28" height="13" rx="3" fill="#0a0a1a" stroke="#22d3ee" stroke-width="1.5"/>
          <!-- Right arm – EXTENDED GIANT PUNCH -->
          <rect x="30" y="-56" width="62" height="18" rx="3" fill="#0a0a1a" stroke="#22d3ee" stroke-width="2"/>
          <!-- GIANT FIST -->
          <rect x="92" y="-62" width="32" height="30" rx="5" fill="#0a0a1a" stroke="#22d3ee" stroke-width="2.5"/>
          <!-- Knuckle lines -->
          <line x1="100" y1="-55" x2="117" y2="-55" stroke="#22d3ee" stroke-width="1.5"/>
          <line x1="100" y1="-47" x2="117" y2="-47" stroke="#22d3ee" stroke-width="1.5"/>
          <!-- Head – perfectly bald -->
          <ellipse cx="0" cy="-86" rx="25" ry="27" fill="#0a0a1a" stroke="#22d3ee" stroke-width="2"/>
          <!-- Bald highlight -->
          <ellipse cx="-8" cy="-96" rx="7" ry="4" fill="white" opacity="0.12"/>
          <!-- Serious half-closed eyes -->
          <line x1="-13" y1="-88" x2="-4" y2="-86" stroke="#22d3ee" stroke-width="3" stroke-linecap="round"/>
          <line x1="4" y1="-86" x2="13" y2="-88" stroke="#22d3ee" stroke-width="3" stroke-linecap="round"/>
          <line x1="-7" y1="-75" x2="7" y2="-75" stroke="#22d3ee" stroke-width="1.5" stroke-linecap="round"/>
          <!-- OPM punch shockwave rings (hidden) -->
          <g id="ls-opm-rings" opacity="0">
            <circle cx="124" cy="-47" r="0" fill="none" stroke="#22d3ee" stroke-width="4" class="ls-opm-ring"/>
            <circle cx="124" cy="-47" r="0" fill="none" stroke="white" stroke-width="2.5" class="ls-opm-ring"/>
            <circle cx="124" cy="-47" r="0" fill="none" stroke="#22d3ee" stroke-width="1.5" class="ls-opm-ring"/>
            <circle cx="124" cy="-47" r="0" fill="none" stroke="#f472b6" stroke-width="1" class="ls-opm-ring"/>
          </g>
        </g>

        <!-- ══ ROCKET #1 (lower-left arcs up-right) ══ -->
        <g id="ls-rocket" transform="translate(-120, 650)">
          <polygon points="-18,22 -36,50 -16,24" fill="#c084fc"/>
          <polygon points="18,22 36,50 16,24" fill="#c084fc"/>
          <polygon points="0,-50 20,28 -20,28" fill="#f472b6"/>
          <polygon points="0,-50 9,-26 -9,-26" fill="#fbbf24"/>
          <circle cx="0" cy="-20" r="10" fill="#0a0f0a" stroke="#22d3ee" stroke-width="2.5"/>
          <circle cx="0" cy="-20" r="5" fill="#22d3ee" opacity="0.7" filter="url(#ls-glow-cyan)"/>
          <ellipse id="ls-rocket-flame" cx="0" cy="43" rx="13" ry="24" fill="#f472b6" opacity="0.95"/>
