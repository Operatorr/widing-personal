---
import PrintLayout from '../layouts/PrintLayout.astro';
import resume from '../data/resume.json';

const { basics, work, education, skills, projects, certificates, languages } = resume;

const formatDate = (dateStr: string) => {
  if (!dateStr) return '';
  const date = new Date(dateStr);
  return date.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
};

const formatYear = (dateStr: string) => {
  if (!dateStr) return '';
  return dateStr.split('-')[0];
};

const mainWork = work;
---

<PrintLayout title={`${basics.name} - CV`}>
  <!-- Header -->
  <header class="mb-4 pb-3 border-b border-gray-300">
    <h1 class="text-2xl font-bold text-black">{basics.name}</h1>
    <p class="text-sm text-gray-600">{basics.label}</p>
    <div class="mt-2 text-xs text-gray-700">
      <span id="email-display" class="hidden"><span id="email-value"></span> | </span>
      <span id="phone-display" class="hidden"><span id="phone-value"></span> | </span>
      {basics.location && (
        <span>{basics.location.city}, {basics.location.countryCode}</span>
      )}
      {basics.url && (
        <span> | <a href={basics.url} class="text-gray-700">{basics.url.replace('https://', '')}</a></span>
      )}
      {basics.profiles?.map((profile) => (
        <span> | <a href={profile.url} class="text-gray-700">{profile.url.replace('https://', '')}</a></span>
      ))}
    </div>
  </header>

  <!-- Summary -->
  {basics.summary && (
    <section class="mb-4">
      <h2 class="text-sm font-bold text-black uppercase tracking-wide mb-2 pb-1 border-b border-gray-300">Summary</h2>
      <p class="text-xs text-black leading-relaxed">{basics.summary}</p>
    </section>
  )}

  <!-- Technical Skills -->
  {skills && skills.length > 0 && (
    <section class="mb-4">
      <h2 class="text-sm font-bold text-black uppercase tracking-wide mb-2 pb-1 border-b border-gray-300">Technical Skills</h2>
      <div class="space-y-1">
        {skills.map((skill) => (
          <p class="text-xs text-black">
            <span class="font-semibold">{skill.name}:</span> {skill.keywords?.join(', ')}
          </p>
        ))}
      </div>
    </section>
  )}

  <!-- Work Experience -->
  {mainWork && mainWork.length > 0 && (
    <section class="mb-4">
      <h2 class="text-sm font-bold text-black uppercase tracking-wide mb-2 pb-1 border-b border-gray-300">Work Experience</h2>
      <div class="space-y-3">
        {mainWork.map((job) => (
          <div class="avoid-break">
            <div class="flex justify-between items-start">
              <h3 class="font-semibold text-black text-sm">{job.position}</h3>
              <span class="text-xs text-gray-600 whitespace-nowrap ml-4">
                {formatDate(job.startDate)} – {job.endDate ? formatDate(job.endDate) : 'Present'}
              </span>
            </div>
            <p class="text-xs text-gray-700">
              {job.name}{job.location && ` · ${job.location}`}
            </p>
            {job.summary && (
              <p class="text-xs text-gray-700 mt-0.5">{job.summary}</p>
            )}
            {job.highlights && job.highlights.length > 0 && (
              <ul class="list-disc list-outside ml-4 mt-1 text-xs text-gray-700 space-y-0">
                {job.highlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            )}
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Selected Projects -->
  {projects && projects.length > 0 && (
    <section class="mb-4">
      <h2 class="text-sm font-bold text-black uppercase tracking-wide mb-2 pb-1 border-b border-gray-300">Selected Projects</h2>
      <div class="space-y-3">
        {projects.slice(0, 4).map((project) => (
          <div class="avoid-break">
            <div class="flex justify-between items-start">
              <div>
                <h3 class="font-semibold text-black text-xs inline">{project.name}</h3>
                {project.entity && <span class="text-xs text-gray-600"> at {project.entity}</span>}
                {project.roles && project.roles.length > 0 && (
                  <span class="text-xs text-gray-600"> — {project.roles.join(', ')}</span>
                )}
              </div>
              <span class="text-xs text-gray-600 whitespace-nowrap ml-4">
                {formatYear(project.startDate)}{project.endDate && ` – ${formatYear(project.endDate)}`}
              </span>
            </div>
            <p class="text-xs text-gray-700 mt-0.5">{project.description}</p>
            {project.highlights && project.highlights.length > 0 && (
              <ul class="list-disc list-outside ml-4 mt-1 text-xs text-gray-700 space-y-0">
                {project.highlights.map((highlight) => (
                  <li>{highlight}</li>
                ))}
              </ul>
            )}
            {project.keywords && project.keywords.length > 0 && (
              <p class="text-xs text-gray-600 mt-1">
                <span class="font-semibold">Technologies:</span> {project.keywords.join(', ')}
              </p>
            )}
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Education -->
  {education && education.length > 0 && (
    <section class="mb-4">
      <h2 class="text-sm font-bold text-black uppercase tracking-wide mb-2 pb-1 border-b border-gray-300">Education</h2>
      <div class="space-y-2">
        {education.slice(0, 3).map((edu) => (
          <div class="avoid-break flex justify-between items-start">
            <div>
              <h3 class="font-medium text-black text-xs">{edu.studyType} in {edu.area}</h3>
              <p class="text-xs text-gray-600">{edu.institution}</p>
            </div>
            <span class="text-xs text-gray-600 whitespace-nowrap ml-4">{formatYear(edu.startDate)} – {formatYear(edu.endDate)}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Certifications -->
  {certificates && certificates.length > 0 && (
    <section class="mb-4">
      <h2 class="text-sm font-bold text-black uppercase tracking-wide mb-2 pb-1 border-b border-gray-300">Certifications</h2>
      <div class="space-y-2">
        {certificates.map((cert) => (
          <div class="avoid-break flex justify-between items-start">
            <div>
              <h3 class="font-medium text-black text-xs">{cert.name}</h3>
              <p class="text-xs text-gray-600">{cert.issuer}</p>
              {cert.highlights && cert.highlights.length > 0 && (
                <p class="text-xs text-gray-600">{cert.highlights.join(', ')}</p>
              )}
            </div>
            <span class="text-xs text-gray-600 whitespace-nowrap ml-4">{formatYear(cert.date)}</span>
          </div>
        ))}
      </div>
    </section>
  )}

  <!-- Languages -->
  {languages && languages.length > 0 && (
    <section class="mb-3">
      <h2 class="text-sm font-bold text-black uppercase tracking-wide mb-2 pb-1 border-b border-gray-300">Languages</h2>
      <p class="text-xs text-black">
        {languages.map((lang, i) => (
          <span>{lang.language} ({lang.fluency}){i < languages.length - 1 ? ' | ' : ''}</span>
        ))}
      </p>
    </section>
  )}

  <!-- Floating controls (hidden in print) -->
  <div class="no-print fixed bottom-5 right-5 z-50 flex flex-col items-end gap-3">
    <div id="contact-panel" class="hidden bg-white rounded-lg shadow-lg border border-gray-200 p-4 w-72 space-y-3">
      <p class="text-xs font-medium text-gray-500 uppercase tracking-wide">Contact Info</p>
      <p class="text-xs text-gray-400 -mt-1">This is for the site owner to add contact details before printing to PDF.</p>
      <input
        type="email"
        id="email-input"
        placeholder="Email"
        class="text-sm border border-gray-300 rounded px-2 py-1.5 w-full focus:outline-none focus:border-gray-500"
      />
      <input
        type="tel"
        id="phone-input"
        placeholder="Phone"
        class="text-sm border border-gray-300 rounded px-2 py-1.5 w-full focus:outline-none focus:border-gray-500"
      />
      <div class="flex gap-2 pt-1">
        <a href="/" class="bg-gray-200 hover:bg-gray-300 text-gray-800 px-3 py-1.5 text-sm font-medium rounded transition-colors">
          ← Back
        </a>
        <button onclick="window.print()" class="bg-gray-800 hover:bg-gray-900 text-white px-3 py-1.5 text-sm font-medium rounded transition-colors ml-auto">
          Print / Save PDF
        </button>
      </div>
    </div>
    <button
      id="contact-toggle"
      class="w-12 h-12 bg-gray-800 hover:bg-gray-900 text-white rounded-full shadow-lg flex items-center justify-center transition-colors"
      aria-label="Toggle contact info"
    >
      <svg id="toggle-icon-open" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
      <svg id="toggle-icon-close" xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </div>
</PrintLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const emailInput = document.getElementById('email-input') as HTMLInputElement;
    const phoneInput = document.getElementById('phone-input') as HTMLInputElement;
    const emailDisplay = document.getElementById('email-display');
    const phoneDisplay = document.getElementById('phone-display');
    const emailValue = document.getElementById('email-value');
    const phoneValue = document.getElementById('phone-value');
    const contactPanel = document.getElementById('contact-panel');
    const contactToggle = document.getElementById('contact-toggle');
    const iconOpen = document.getElementById('toggle-icon-open');
    const iconClose = document.getElementById('toggle-icon-close');

    const savedEmail = localStorage.getItem('cv-email') || '';
    const savedPhone = localStorage.getItem('cv-phone') || '';

    if (emailInput) emailInput.value = savedEmail;
    if (phoneInput) phoneInput.value = savedPhone;

    const updateDisplay = () => {
      const email = emailInput?.value || '';
      const phone = phoneInput?.value || '';

      if (email && emailDisplay && emailValue) {
        emailDisplay.style.display = 'inline';
        emailValue.textContent = email;
      } else if (emailDisplay) {
        emailDisplay.style.display = 'none';
      }

      if (phone && phoneDisplay && phoneValue) {
        phoneDisplay.style.display = 'inline';
        phoneValue.textContent = phone;
      } else if (phoneDisplay) {
        phoneDisplay.style.display = 'none';
      }
    };

    updateDisplay();

    contactToggle?.addEventListener('click', () => {
      const opening = contactPanel?.classList.toggle('hidden') === false;
      iconOpen?.classList.toggle('hidden', opening);
      iconClose?.classList.toggle('hidden', !opening);
    });

    emailInput?.addEventListener('input', () => {
      localStorage.setItem('cv-email', emailInput.value);
      updateDisplay();
    });

    phoneInput?.addEventListener('input', () => {
      localStorage.setItem('cv-phone', phoneInput.value);
      updateDisplay();
    });
  });
</script>
